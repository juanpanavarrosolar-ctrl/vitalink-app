# Supabase — Get these from your Supabase project dashboard (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Only used in server-side code (API routes, Server Actions)
# Never expose this key to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL (used for auth redirects and email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Flow Chile — Payment gateway (sandbox: https://sandbox.flow.cl)
FLOW_API_KEY=your-flow-api-key
FLOW_SECRET_KEY=your-flow-secret-key
FLOW_API_URL=https://sandbox.flow.cl/app/web/services/rest/v4

# Resend — Transactional email
RESEND_API_KEY=re_your-resend-api-key

# Cron security secret (generate with: openssl rand -hex 32)
CRON_SECRET=your-cron-secret-here

# Admin contact
ADMIN_EMAIL=admin@vitalink.cl

# Groq API — AI agents (NutriCoach Pro + NutriGuía)
# Free tier: 14,400 requests/day — get key at console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key
